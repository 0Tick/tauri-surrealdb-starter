{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Tauri SurrealDB Starter",
    "version": "0.1.0",
    "identifier": "dev.starter.taurisurreal",
    "build": {
        "beforeDevCommand": "npm run dev --workspace @starter/app",
        "beforeBuildCommand": "npm run build --workspace @starter/app",
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420"
    },
    "app": {
        "security": {
            "csp": null
        },
        "windows": [
            {
                "title": "Tauri SurrealDB Starter",
                "width": 900,
                "height": 700,
                "resizable": true,
                "devtools": true
            }
        ]
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": []
    }
}