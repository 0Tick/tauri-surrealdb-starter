{
    "name": "tauri-surrealdb-starter",
    "private": true,
    "version": "0.1.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "npm run dev --workspace @starter/app",
        "tauri:dev": "npm run tauri:dev --workspace @starter/app",
