{
    "name": "@starter/app",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit && npm run typecheck --workspace @starter/surrealdb-js-tauri",
        "test": "vitest run",
        "test:watch": "vitest",
        "tauri:dev": "tauri dev",
        "tauri:build": "tauri build",
        "android:dev": "tauri android dev",
        "tauri": "tauri"
    },
    "dependencies": {
        "@starter/surrealdb-js-tauri": "file:packages/surrealdb-js-tauri"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2.1.0",
        "typescript": "^5.6.3",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    }
}
